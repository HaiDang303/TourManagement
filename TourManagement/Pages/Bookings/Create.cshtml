@page
@model TourManagement.Pages.Bookings.CreateModel
@{
    ViewData["Title"] = "Đặt booking";
}

<style>
    .booking-page {
        background: #f7fbff;
        padding: 150px 0 80px;
    }

    .booking-grid {
        display: grid;
        grid-template-columns: 1.1fr .9fr;
        gap: 30px;
        align-items: start;
    }

    .booking-card,
    .booking-summary {
        background: white;
        border-radius: 22px;
        box-shadow: 0 12px 35px rgba(12,31,56,.08);
    }

    .booking-card {
        padding: 30px;
    }

    .booking-summary {
        padding: 28px;
        position: sticky;
        top: 110px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group.full {
            grid-column: 1 / -1;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #102542;
            margin-bottom: 8px;
        }

    .form-control, .form-select {
        width: 100%;
        border: 1px solid #dce8f2;
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 15px;
        outline: none;
        background: #fff;
    }

        .form-control:focus, .form-select:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13,110,253,.08);
        }

    .summary-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid #edf3f8;
        color: #5f7289;
    }

        .summary-row strong {
            color: #102542;
        }

    .summary-price {
        font-size: 30px;
        font-weight: 800;
        color: #0d6efd;
        margin-top: 18px;
    }

    .validation-summary-errors {
        background: #fff4f4;
        border: 1px solid #ffd2d2;
        color: #c62828;
        padding: 14px 16px;
        border-radius: 14px;
        margin-bottom: 18px;
    }

    @@media (max-width: 991px) {
        .booking-grid,
        .form-grid {
            grid-template-columns: 1fr;
        }

        .booking-summary {
            position: static;
        }
    }
</style>

<section class="booking-page">
    <div class="container">
        <p class="section-subtitle">Đặt tour</p>
        <h1 class="h2 section-title">Thông tin booking của bạn</h1>
        <p class="section-text" style="margin-bottom:34px;">
            Xác nhận số lượng hành khách và ghi chú cần thiết trước khi chuyển sang bước nhập danh sách hành khách.
        </p>

        <div class="booking-grid">
            <div class="booking-card">
                <h3 class="h3" style="margin-bottom:20px;">Thông tin đặt tour</h3>

                <div asp-validation-summary="ModelOnly"></div>

                <form method="post">
                    <input type="hidden" asp-for="Input.GroupId" />

                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="Input.Adults">Người lớn</label>
                            <input asp-for="Input.Adults" type="number" min="1" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label asp-for="Input.Children">Trẻ em</label>
                            <input asp-for="Input.Children" type="number" min="0" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label asp-for="Input.Infants">Em bé</label>
                            <input asp-for="Input.Infants" type="number" min="0" class="form-control" />
                        </div>

                        <div class="form-group full">
                            <label asp-for="Input.Notes">Ghi chú</label>
                            <textarea asp-for="Input.Notes" rows="5" class="form-control"
                                      placeholder="Nhập yêu cầu đặc biệt, ghi chú liên hệ hoặc lưu ý cho chuyến đi..."></textarea>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-secondary">
                        Tiếp tục nhập hành khách
                    </button>
                    <div style="margin-top:20px;">
                        <a asp-page="/Index" class="btn btn-primary">Về trang chủ</a>
                    </div>
                </form>
            </div>

            <aside class="booking-summary">
                <p class="section-subtitle">Tóm tắt</p>
                <h3 class="h3 section-title" style="margin-bottom:16px;">Chi tiết đợt khởi hành</h3>

                @if (Model.Group != null && Model.Tour != null)
                {
                    var remain = Model.Group.MaxCapacity - Model.Group.CurrentBookings;

                    <div class="summary-row">
                        <span>Tên tour</span>
                        <strong>@Model.Tour.Name</strong>
                    </div>
                    <div class="summary-row">
                        <span>Mã đoàn</span>
                        <strong>@Model.Group.GroupId</strong>
                    </div>
                    <div class="summary-row">
                        <span>Ngày đi</span>
                        <strong>@Model.Group.DepartDate.ToString("dd/MM/yyyy")</strong>
                    </div>
                    <div class="summary-row">
                        <span>Ngày về</span>
                        <strong>@Model.Group.ReturnDate.ToString("dd/MM/yyyy")</strong>
                    </div>
                    <div class="summary-row">
                        <span>Chỗ còn lại</span>
                        <strong>@remain / @Model.Group.MaxCapacity</strong>
                    </div>
                    <div class="summary-row">
                        <span>Giá cơ bản</span>
                        <strong>@Model.Tour.BasePrice.ToString("N0") VNĐ</strong>
                    </div>

                    <div class="summary-price">
                        @Model.Tour.BasePrice.ToString("N0") VNĐ
                    </div>
                    <p style="color:#7b8ea4; margin-top:4px;">Áp dụng cho 1 người lớn</p>
                }
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}