@page "{bookingId}"
@model TourManagement.Pages.Bookings.PassengersModel
@{
    ViewData["Title"] = "Thông tin hành khách";
}

<style>
    .passenger-page {
        background: #f7fbff;
        padding: 150px 0 80px;
    }

    .passenger-wrapper {
        max-width: 1050px;
        margin: 0 auto;
    }

    .passenger-card {
        background: white;
        border-radius: 22px;
        padding: 28px;
        box-shadow: 0 12px 35px rgba(12,31,56,.08);
        margin-bottom: 24px;
    }

    .passenger-head {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
        margin-bottom: 18px;
    }

    .passenger-index {
        font-size: 18px;
        font-weight: 700;
        color: #102542;
    }

    .passenger-badge {
        background: rgba(13,110,253,.1);
        color: #0d6efd;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: #102542;
        font-weight: 600;
    }

    .form-control, .form-select {
        width: 100%;
        border: 1px solid #dce8f2;
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 15px;
        background: white;
    }

        .form-control:focus, .form-select:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13,110,253,.08);
            outline: none;
        }

    .full-row {
        grid-column: 1 / -1;
    }

    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-top: 30px;
    }

    .booking-mini {
        color: #6a7d93;
        font-weight: 600;
    }

    @@media (max-width: 991px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .action-bar {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

<section class="passenger-page">
    <div class="container">
        <div class="passenger-wrapper">
            <p class="section-subtitle">Hành khách</p>
            <h1 class="h2 section-title">Nhập danh sách hành khách</h1>
            <p class="section-text" style="margin-bottom:28px;">
                Hoàn thiện thông tin cho từng hành khách để tiếp tục sang bước thanh toán.
            </p>

            <form method="post">
                @for (int i = 0; i < Model.Passengers.Count; i++)
                {
                    <div class="passenger-card">
                        <div class="passenger-head">
                            <div class="passenger-index">Hành khách @(i + 1)</div>
                            <div class="passenger-badge">@Model.Passengers[i].CategoryId</div>
                        </div>

                        <input type="hidden" asp-for="Passengers[i].CategoryId" />

                        <div class="form-grid">
                            <div class="form-group">
                                <label asp-for="Passengers[i].FullName">Họ và tên</label>
                                <input asp-for="Passengers[i].FullName" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="Passengers[i].GenderId">Giới tính</label>
                                <select asp-for="Passengers[i].GenderId" class="form-select">
                                    <option value="">-- Chọn giới tính --</option>
                                    <option value="M">Nam</option>
                                    <option value="F">Nữ</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label asp-for="Passengers[i].Dob">Ngày sinh</label>
                                <input asp-for="Passengers[i].Dob" type="date" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="Passengers[i].PassportNo">Passport / CCCD</label>
                                <input asp-for="Passengers[i].PassportNo" class="form-control" />
                            </div>

                            <div class="form-group full-row">
                                <label asp-for="Passengers[i].Notes">Ghi chú</label>
                                <textarea asp-for="Passengers[i].Notes" rows="3" class="form-control"
                                          placeholder="Ghi chú riêng cho hành khách này..."></textarea>
                            </div>
                        </div>
                    </div>
                }

                <div class="action-bar">
                    <div class="booking-mini">
                        Vui lòng kiểm tra kỹ thông tin trước khi chuyển sang thanh toán.
                    </div>

                    <button type="submit" class="btn btn-secondary">
                        Tiếp tục thanh toán
                    </button>
                    <div style="margin-top:20px;">
                        <a asp-page="/Index" class="btn btn-primary">Về trang chủ</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}