@page
@model TourManagement.Pages.Admin.Payments.IndexModel
@{
    ViewData["Title"] = "Quản lý thanh toán";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="admin-payments-body">
<div class="admin-page">
    <div class="page-header">
        <h1>Quản lý thanh toán</h1>
        <a href="/Admin/Dashboard" class="btn btn-outline-light">Dashboard</a>
    </div>
    @if (TempData["Success"] != null)
    { <div class="alert alert-success">@TempData["Success"]</div> }
    @if (TempData["Error"] != null)
    { <div class="alert alert-danger">@TempData["Error"]</div> }

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(Model.Tab == "pending" ? "active" : "")" href="?tab=pending">
                Chưa xác nhận (@Model.PendingPayments.Count)
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.Tab == "all" ? "active" : "")" href="?tab=all">
                Lịch sử giao dịch
            </a>
        </li>
    </ul>

    <div class="card admin-card">
        <div class="card-body">
            @if (Model.Tab == "pending")
            {
                if (!Model.PendingPayments.Any())
                {
                    <p class="text-muted">Không có thanh toán chờ xác nhận.</p>
                }
                else
                {
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Mã TT</th>
                                <th>Booking</th>
                                <th>Khách hàng</th>
                                <th>Tour</th>
                                <th>Ngày đi</th>
                                <th>Số tiền</th>
                                <th>Phương thức</th>
                                <th>Ngày TT</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.PendingPayments)
                            {
                                <tr>
                                    <td>@p.PaymentId</td>
                                    <td>@p.BookingId</td>
                                    <td>@p.CustomerName</td>
                                    <td>@p.TourName</td>
                                    <td>@p.DepartDate?.ToString("dd/MM/yyyy")</td>
                                    <td>@p.Amount.ToString("N0") đ</td>
                                    <td>@p.Method</td>
                                    <td>@p.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã TT</th>
                            <th>Booking</th>
                            <th>Khách hàng</th>
                            <th>Tour</th>
                            <th>Số tiền</th>
                            <th>Phương thức</th>
                            <th>Ngày TT</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.AllPayments)
                        {
                            <tr>
                                <td>@p.PaymentId</td>
                                <td>@p.BookingId</td>
                                <td>@p.CustomerName</td>
                                <td>@p.TourName</td>
                                <td>@p.Amount.ToString("N0") đ</td>
                                <td>@p.Method</td>
                                <td>@p.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (p.IsPaid)
                                    { <span class="badge bg-success">@p.StatusName</span> }
                                    else
                                    { <span class="badge bg-warning">@p.StatusName</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<style>
    .admin-page { padding: 24px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .page-header h1 { font-size: 1.5rem; color: #fff; margin: 0; }
    .admin-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #e2e8f0; }
    .admin-card .table { color: #e2e8f0; }
    .admin-card .table th { border-color: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); }
    .admin-card .table td { border-color: rgba(255,255,255,0.08); }
    .admin-payments-body { background: #0f172a; min-height: 100vh; }
    .nav-tabs { border-color: rgba(255,255,255,0.1); }
    .nav-tabs .nav-link { color: rgba(255,255,255,0.6); border-color: transparent; }
    .nav-tabs .nav-link:hover { color: #fff; border-color: rgba(255,255,255,0.15); }
    .nav-tabs .nav-link.active { background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.15); }
</style>
</body>
</html>
