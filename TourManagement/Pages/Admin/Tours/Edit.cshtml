@page "{id}"
@model TourManagement.Pages.Admin.Tours.EditModel
@{
    ViewData["Title"] = "Sửa tour";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

<div class="container mt-4">
    <h2 class="mb-3">Sửa tour</h2>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Mã tour</label>
            <input class="form-control" value="@Model.TourId" disabled />
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Input.Name" class="form-label"></label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Input.DestinationId" class="form-label"></label>
                    <select asp-for="Input.DestinationId" class="form-select">
                        @foreach (var d in Model.Destinations)
                        {
                            <option value="@d.DestinationId">@d.Name (@d.City)</option>
                        }
                    </select>
                    <span asp-validation-for="Input.DestinationId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Input.DurationDays" class="form-label"></label>
            <input asp-for="Input.DurationDays" class="form-control" />
            <span asp-validation-for="Input.DurationDays" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="Input.StartDate" class="form-label"></label>
                    <input asp-for="Input.StartDate" class="form-control" />
                    <span asp-validation-for="Input.StartDate" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="Input.EndDate" class="form-label"></label>
                    <input asp-for="Input.EndDate" class="form-control" />
                    <span asp-validation-for="Input.EndDate" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="Input.AvailableSeats" class="form-label"></label>
                    <input asp-for="Input.AvailableSeats" class="form-control" />
                    <span asp-validation-for="Input.AvailableSeats" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Category" class="form-label"></label>
            <input asp-for="Input.Category" class="form-control" />
            <span asp-validation-for="Input.Category" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.MaxParticipants" class="form-label"></label>
            <input asp-for="Input.MaxParticipants" class="form-control" />
            <span asp-validation-for="Input.MaxParticipants" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Price" class="form-label"></label>
            <input asp-for="Input.Price" class="form-control" />
            <span asp-validation-for="Input.Price" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Description" class="form-label"></label>
            <textarea asp-for="Input.Description" class="form-control"></textarea>
            <span asp-validation-for="Input.Description" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        <a href="/Admin/Tours" class="btn btn-secondary ms-2">Hủy</a>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

