@page
@model TourManagement.Pages.Admin.Tours.IndexModel
@{
    ViewData["Title"] = "Quản lý tour";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0">Quản lý tour</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/Admin/Dashboard">Dashboard</a>
            <a class="btn btn-primary" href="/Admin/Tours/Create">+ Thêm tour</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>IMAGE</th>
                        <th>DESCRIPTION</th>
                        <th>START DATE</th>
                        <th>END DATE</th>
                        <th>PRICE</th>
                        <th>AVAIABLESEATS</th>
                        <th>CATEGORY</th>
                        <th>CITY</th>
                        <th>ACTION</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Rows)
                {
                    <tr>
                        <td class="text-muted">@r.Stt</td>
                        <td class="text-muted">—</td>
                        <td>
                            <div class="fw-semibold">@r.Name</div>
                            <div class="text-muted small text-truncate" style="max-width: 420px">@r.Description</div>
                        </td>
                        <td>@(r.StartDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@(r.EndDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@r.Price.ToString("N0")</td>
                        <td>@(r.AvailableSeats?.ToString() ?? "—")</td>
                        <td>@r.Category</td>
                        <td>@r.City</td>
                        <td class="text-nowrap">
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Tours/Edit" asp-route-id="@r.TourId">Sửa</a>
                            <a class="btn btn-sm btn-outline-danger ms-1" asp-page="/Admin/Tours/Delete" asp-route-id="@r.TourId">Xóa</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

