@page "{id}"
@model TourManagement.Pages.Admin.Tours.DeleteModel
@{
    ViewData["Title"] = "Xóa tour";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

<div class="container mt-4">
    <h2 class="mb-3 text-danger">Xóa tour</h2>

    <div class="alert alert-warning">
        Bạn chắc chắn muốn xóa tour này?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Mã tour</dt>
        <dd class="col-sm-9">@Model.Tour?.TourId</dd>

        <dt class="col-sm-3">Tên tour</dt>
        <dd class="col-sm-9">@Model.Tour?.Name</dd>

        <dt class="col-sm-3">Điểm đến</dt>
        <dd class="col-sm-9">@Model.Tour?.Destination?.Name</dd>
    </dl>

    <form method="post" asp-route-id="@Model.Tour?.TourId">
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a href="/Admin/Tours" class="btn btn-secondary ms-2">Hủy</a>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

