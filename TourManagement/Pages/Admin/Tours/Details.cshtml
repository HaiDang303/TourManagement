@page "{id}"
@model TourManagement.Pages.Admin.Tours.DetailsModel
@{
    ViewData["Title"] = "Chi tiết tour";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="m-0">Chi tiết tour</h2>
        <div>
            <a href="/Admin/Tours/Edit/@Model.Tour?.TourId" class="btn btn-primary">Sửa</a>
            <a href="/Admin/Tours" class="btn btn-outline-secondary ms-2">Quay lại</a>
        </div>
    </div>

    @if (Model.Tour == null)
    {
        <div class="alert alert-warning">Không tìm thấy tour.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        @if (!string.IsNullOrWhiteSpace(Model.Tour.ImageUrl))
                        {
                            <img src="@Model.Tour.ImageUrl" class="img-fluid rounded" alt="@Model.Tour.Name" style="max-height: 280px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="height: 200px;">Chưa có ảnh</div>
                        }
                    </div>
                    <div class="col-md-8">
                        <h4>@Model.Tour.Name</h4>
                        <p class="text-muted">@Model.Tour.Description</p>
                        <dl class="row">
                            <dt class="col-sm-3">Mã tour</dt>
                            <dd class="col-sm-9">@Model.Tour.TourId</dd>

                            <dt class="col-sm-3">Điểm đến (Destination)</dt>
                            <dd class="col-sm-9">
                                @if (Model.Tour.Destination != null)
                                {
                                    <span>@Model.Tour.Destination.Name</span>
                                    <span class="text-muted">— @Model.Tour.Destination.City, @Model.Tour.Destination.Country</span>
                                    @if (!string.IsNullOrWhiteSpace(Model.Tour.Destination.Description))
                                    {
                                        <div class="small mt-1">@Model.Tour.Destination.Description</div>
                                    }
                                }
                                else
                                { <span class="text-muted">—</span> }
                            </dd>

                            <dt class="col-sm-3">Thời lượng</dt>
                            <dd class="col-sm-9">@Model.Tour.DurationDays ngày</dd>

                            <dt class="col-sm-3">Giá</dt>
                            <dd class="col-sm-9">@Model.Tour.BasePrice.ToString("N0") ₫</dd>

                            <dt class="col-sm-3">Danh mục</dt>
                            <dd class="col-sm-9">@(Model.Tour.Category ?? "—")</dd>

                            <dt class="col-sm-3">Số người tối đa</dt>
                            <dd class="col-sm-9">@(Model.Tour.MaxParticipants?.ToString() ?? "—")</dd>

                            <dt class="col-sm-3">Ngày tạo</dt>
                            <dd class="col-sm-9">@Model.Tour.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                            <dt class="col-sm-3">Cập nhật</dt>
                            <dd class="col-sm-9">@(Model.Tour.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>
                        </dl>
                    </div>
                </div>

                <h5 class="mt-4">Các đoàn (TourGroup)</h5>
                <table class="table table-sm">
                    <thead><tr><th>GroupId</th><th>Khởi hành</th><th>Về</th><th>Sức chứa</th><th>Đã đặt</th><th>Trạng thái</th></tr></thead>
                    <tbody>
                    @foreach (var g in Model.Tour.TourGroups ?? new List<TourGroup>())
                    {
                        <tr>
                            <td>@g.GroupId</td>
                            <td>@g.DepartDate.ToString("dd/MM/yyyy")</td>
                            <td>@g.ReturnDate.ToString("dd/MM/yyyy")</td>
                            <td>@g.MaxCapacity</td>
                            <td>@g.CurrentBookings</td>
                            <td>@g.StatusId</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
</body>
</html>
