@page
@model TourManagement.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<h2 class="mb-4">Quản lý người dùng</h2>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Số điện thoại</th>
            <th>Vai trò</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var user in Model.Users)
    {
        <tr>
            <td>@user.Id</td>
            <td>@user.Name</td>
            <td>@user.Email</td>
            <td>@user.Phone</td>
            <td>@user.Role?.RoleName</td>
            <td>
                @if (user.IsActive)
                {
                    <span class="badge bg-success">Hoạt động</span>
                }
                else
                {
                    <span class="badge bg-secondary">Khóa</span>
                }
            </td>
            <td class="text-nowrap">
                <form method="post" asp-page-handler="ToggleActive" asp-route-id="@user.Id" class="d-inline">
                    <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-warning" : "btn-success")">
                        @(user.IsActive ? "Khóa" : "Mở khóa")
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

