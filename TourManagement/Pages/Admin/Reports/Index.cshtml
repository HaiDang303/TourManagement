@page
@model TourManagement.Pages.Admin.Reports.IndexModel
@{
    ViewData["Title"] = "Báo cáo";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="reports-body">
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white mb-0">Báo cáo</h2>
        <a href="/Admin/Dashboard" class="btn btn-outline-light">Dashboard</a>
    </div>

    <form method="get" class="card mb-4 p-3" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label text-white-50 small">Từ ngày</label>
                <input type="date" name="FromDate" class="form-control form-control-sm bg-dark text-white border-secondary"
                       value="@(Model.FromDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.AddMonths(-3).ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label class="form-label text-white-50 small">Đến ngày</label>
                <input type="date" name="ToDate" class="form-control form-control-sm bg-dark text-white border-secondary"
                       value="@(Model.ToDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm">Xem báo cáo</button>
            </div>
        </div>
    </form>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100" style="background:linear-gradient(135deg,#0d9488,#059669);border:none;">
                <div class="card-body text-white">
                    <div class="small opacity-75">Doanh thu (đã TT)</div>
                    <h3 class="mb-0">@Model.TotalRevenue.ToString("N0") đ</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100" style="background:linear-gradient(135deg,#4f46e5,#7c3aed);border:none;">
                <div class="card-body text-white">
                    <div class="small opacity-75">Số lượng booking</div>
                    <h3 class="mb-0">@Model.TotalBookings</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                <div class="card-header text-white border-secondary">Doanh thu theo tour</div>
                <div class="card-body p-0">
                    <table class="table table-dark table-hover mb-0">
                        <thead><tr><th>Tour</th><th>Doanh thu</th><th>SL</th></tr></thead>
                        <tbody>
                            @foreach (var r in Model.RevenueByTour)
                            {
                                <tr>
                                    <td>@r.TourName</td>
                                    <td>@r.Revenue.ToString("N0") đ</td>
                                    <td>@r.Bookings</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                <div class="card-header text-white border-secondary">Doanh thu theo tháng</div>
                <div class="card-body p-0">
                    <table class="table table-dark table-hover mb-0">
                        <thead><tr><th>Tháng</th><th>Doanh thu</th><th>Booking</th></tr></thead>
                        <tbody>
                            @foreach (var r in Model.RevenueByMonth)
                            {
                                <tr>
                                    <td>@r.Label</td>
                                    <td>@r.Revenue.ToString("N0") đ</td>
                                    <td>@r.Bookings</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-2">
        <div class="col-lg-6">
            <div class="card" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                <div class="card-header text-warning border-secondary">Tour sắp hết chỗ (≥80%)</div>
                <div class="card-body p-0">
                    <table class="table table-dark table-hover mb-0">
                        <thead><tr><th>Tour</th><th>Ngày đi</th><th>Chỗ</th><th>%</th></tr></thead>
                        <tbody>
                            @foreach (var t in Model.ToursAlmostFull)
                            {
                                <tr>
                                    <td>@t.TourName</td>
                                    <td>@t.DepartDate.ToString("dd/MM/yyyy")</td>
                                    <td>@t.CurrentBookings / @t.MaxCapacity</td>
                                    <td><span class="badge bg-warning">@t.PercentFull%</span></td>
                                </tr>
                            }
                            @if (!Model.ToursAlmostFull.Any())
                            { <tr><td colspan="4" class="text-muted">Không có tour nào sắp hết chỗ</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                <div class="card-header text-success border-secondary">Tour đã hoàn thành</div>
                <div class="card-body p-0">
                    <table class="table table-dark table-hover mb-0">
                        <thead><tr><th>Tour</th><th>Số chuyến</th><th>Doanh thu</th></tr></thead>
                        <tbody>
                            @foreach (var t in Model.CompletedTours)
                            {
                                <tr>
                                    <td>@t.TourName</td>
                                    <td>@t.CompletedCount</td>
                                    <td>@t.Revenue.ToString("N0") đ</td>
                                </tr>
                            }
                            @if (!Model.CompletedTours.Any())
                            { <tr><td colspan="3" class="text-muted">Chưa có tour hoàn thành trong khoảng thời gian</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
    .reports-body { background: #0f172a; min-height: 100vh; }
    .table-dark { --bs-table-bg: transparent; --bs-table-color: #e2e8f0; }
</style>
</body>
</html>
