@page "{id}"
@model TourManagement.Pages.Admin.Destinations.DeleteModel
@{ ViewData["Title"] = "Xóa điểm đến"; Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>@ViewData["Title"]</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /></head>
<body class="bg-light">
<div class="container mt-4">
    <h2 class="text-danger">Xóa điểm đến</h2>
    <div class="alert alert-warning">Bạn chắc chắn muốn xóa?</div>
    <dl class="row">
        <dt class="col-sm-3">Mã</dt><dd class="col-sm-9">@Model.Destination?.DestinationId</dd>
        <dt class="col-sm-3">Tên</dt><dd class="col-sm-9">@Model.Destination?.Name</dd>
        <dt class="col-sm-3">Thành phố</dt><dd class="col-sm-9">@Model.Destination?.City</dd>
    </dl>
    <form method="post" asp-route-id="@Model.Destination?.DestinationId">
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a href="/Admin/Destinations" class="btn btn-secondary ms-2">Hủy</a>
    </form>
</div>
</body>
</html>
