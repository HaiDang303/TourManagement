@page "{bookingId}"
@model TourManagement.Pages.Passengers.AddModel


@{
    ViewData["Title"] = "Thêm hành khách - Đặt chỗ " + Model.Booking?.BookingId;
    Layout = null;  // giữ giao diện công khai đơn giản
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white py-4">
                    <h3 class="mb-0 text-center">Thêm hành khách cho đặt chỗ</h3>
                    <p class="text-center mb-1 mt-2">
                        Mã đặt chỗ: <strong>@Model.Booking?.BookingId</strong><br />
                        Tour: <strong>@Model.Booking?.Group?.Tour?.Name</strong>
                    </p>
                    <p class="text-center small mb-0">
                        Đã thêm: @Model.CurrentPassengerCount / @Model.TotalRequiredPassengers hành khách
                    </p>
                </div>

                <div class="card-body p-4 p-md-5">
                    @if (Model.CurrentPassengerCount >= Model.TotalRequiredPassengers)
                    {
                        <div class="alert alert-success text-center py-4">
                            <h5 class="mb-2">Đã thêm đủ hành khách!</h5>
                            <p class="mb-3">Bạn có thể xem lại hoặc tiếp tục thanh toán.</p>
                            <a asp-page="/Bookings/Details" asp-route-id="@Model.Booking?.BookingId"
                               class="btn btn-success btn-lg px-5">
                                Xem chi tiết đặt chỗ →
                            </a>
                        </div>
                    }
                    else
                    {
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-4 text-center fw-bold"></div>

                            <div class="row g-4">
                                <div class="col-md-12">
                                    <label asp-for="Passenger.FullName" class="form-label fw-bold">Họ và tên đầy đủ *</label>
                                    <input asp-for="Passenger.FullName" class="form-control form-control-lg" required />
                                    <span asp-validation-for="Passenger.FullName" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Passenger.Dob" class="form-label fw-bold">Ngày sinh</label>
                                    <input asp-for="Passenger.Dob" type="date" class="form-control form-control-lg" />
                                    <span asp-validation-for="Passenger.Dob" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Passenger.GenderId" class="form-label fw-bold">Giới tính</label>
                                    <select asp-for="Passenger.GenderId" class="form-select form-select-lg" asp-items="Model.Genders">
                                        <option value="">Chọn giới tính</option>
                                    </select>
                                    <span asp-validation-for="Passenger.GenderId" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Passenger.CategoryId" class="form-label fw-bold">Loại hành khách *</label>
                                    <select asp-for="Passenger.CategoryId" class="form-select form-select-lg" required>
                                        <option value="">Chọn loại</option>
                                        @foreach (var cat in Model.PassengerCategories)
                                        {
                                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                                        }
                                    </select>
                                    <span asp-validation-for="Passenger.CategoryId" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Passenger.PassportNo" class="form-label fw-bold">Số hộ chiếu (nếu có)</label>
                                    <input asp-for="Passenger.PassportNo" class="form-control form-control-lg" />
                                    <span asp-validation-for="Passenger.PassportNo" class="text-danger"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Passenger.Notes" class="form-label fw-bold">Ghi chú (dị ứng, yêu cầu đặc biệt...)</label>
                                    <textarea asp-for="Passenger.Notes" class="form-control" rows="3"></textarea>
                                    <span asp-validation-for="Passenger.Notes" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mt-5 d-grid gap-3 d-md-flex justify-content-md-center">
                                <button type="submit" class="btn btn-success btn-lg px-5 py-3">
                                    Thêm hành khách này
                                </button>
                                <a asp-page="/Bookings/Details" asp-route-id="@Model.Booking?.BookingId"
                                   class="btn btn-outline-secondary btn-lg px-5">
                                    Hoàn tất & Xem lại
                                </a>
                            </div>
                        </form>
                    }
                </div>

                <div class="card-footer bg-light text-center py-3">
                    <small class="text-muted">
                        Hành khách đã thêm: @Model.CurrentPassengerCount / @Model.TotalRequiredPassengers
                    </small>
                </div>
            </div>

            <div class="mt-4 text-center">
                <a asp-page="/Bookings/Create" asp-route-groupId="@Model.Booking?.GroupId" class="text-muted">
                    ← Quay lại chỉnh sửa số lượng
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}