@page
@model TourManagement.Pages.Staff.Tours.CreateModel
@{
    ViewData["Title"] = "Tạo lịch khởi hành";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

<div class="container mt-4">
    <h2 class="mb-3">Tạo lịch khởi hành mới</h2>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Input.TourId" class="form-label"></label>
            <select asp-for="Input.TourId" class="form-select">
                <option value="">-- Chọn Tour --</option>
                @foreach (var t in Model.Tours)
                {
                    <option value="@t.TourId">@t.Name</option>
                }
            </select>
            <span asp-validation-for="Input.TourId" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="Input.DepartDate" class="form-label"></label>
                    <input asp-for="Input.DepartDate" class="form-control" />
                    <span asp-validation-for="Input.DepartDate" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="Input.ReturnDate" class="form-label"></label>
                    <input asp-for="Input.ReturnDate" class="form-control" />
                    <span asp-validation-for="Input.ReturnDate" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="Input.MaxCapacity" class="form-label"></label>
                    <input asp-for="Input.MaxCapacity" class="form-control" />
                    <span asp-validation-for="Input.MaxCapacity" class="text-danger"></span>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Lưu lịch khởi hành</button>
        <a href="/Staff/Tours/Index" class="btn btn-secondary ms-2">Quay lại danh sách</a>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
