@page
@model TourManagement.Pages.Staff.Tours.IndexModel
@{
    ViewData["Title"] = "Staff - Danh sách tour đang mở";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0">Luồng 1: Danh sách lịch khởi hành</h2>
        <div>
            <a href="/Staff/Tours/Create" class="btn btn-primary">+ Tạo lịch khởi hành</a>
            <a href="/Staff/Bookings" class="btn btn-outline-primary ms-2">Xử lý booking</a>
            <a href="/Staff/Customers" class="btn btn-outline-primary ms-2">Khách hàng</a>
            <a href="/Admin/Dashboard" class="btn btn-outline-secondary ms-2">Dashboard</a>
        </div>
    </div>

    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

    <form method="get" class="card mb-4 p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Từ ngày</label>
                <input type="date" name="FromDate" class="form-control" value="@(Model.FromDate?.ToString("yyyy-MM-dd") ?? DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Đến ngày</label>
                <input type="date" name="ToDate" class="form-control" value="@(Model.ToDate?.ToString("yyyy-MM-dd") ?? DateOnly.FromDateTime(DateTime.Today.AddMonths(3)).ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary">Lọc</button>
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-header"><strong>Tour đang mở (theo ngày khởi hành)</strong></div>
        <div class="card-body p-0">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Tour</th>
                        <th>Điểm đến</th>
                        <th>Ngày đi – về</th>
                        <th>Chỗ trống</th>
                        <th>Đã xác nhận</th>
                        <th>TT thực tế</th>
                        <th>Cập nhật số chỗ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Groups)
                    {
                        <tr>
                            <td>@r.TourName</td>
                            <td>@r.Destination</td>
                            <td>@r.DepartDate.ToString("dd/MM/yyyy") – @r.ReturnDate.ToString("dd/MM/yyyy")</td>
                            <td>@r.AvailableSeats / @r.MaxCapacity</td>
                            <td>@r.ConfirmedBookings booking</td>
                            <td>
                                <form method="post" asp-page-handler="UpdateStatus" class="d-inline-flex gap-1 align-items-center">
                                    <input type="hidden" name="groupId" value="@r.GroupId" />
                                    <select name="newStatus" class="form-select form-select-sm" style="width:auto">
                                        <option value="OPEN">Mở</option>
                                        <option value="ONGOING">Đang diễn ra</option>
                                        <option value="COMPLETED">Hoàn thành</option>
                                        <option value="CANCELLED_WEATHER">Hủy do TT</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Cập nhật</button>
                                </form>
                            </td>
                            <td>
                                <form method="post" asp-page-handler="UpdateCapacity" class="d-inline-flex gap-1 align-items-center">
                                    <input type="hidden" name="groupId" value="@r.GroupId" />
                                    <input type="number" name="maxCapacity" class="form-control form-control-sm" style="width:80px" value="@r.MaxCapacity" min="@r.CurrentBookings" required />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Lưu</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Groups.Any())
            { <p class="p-3 text-muted mb-0">Không có tour nào trong khoảng thời gian đã chọn.</p> }
        </div>
    </div>
</div>
</body>
</html>
