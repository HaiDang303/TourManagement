@page "{id}"
@model TourManagement.Pages.Staff.Bookings.EditModel
@{
    ViewData["Title"] = "Sửa booking";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
<div class="container my-4">
    <h2>Sửa thông tin booking @Model.Booking?.BookingId</h2>
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
    <form method="post" asp-route-id="@Model.Booking?.BookingId">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label class="form-label">Người lớn</label>
            <input asp-for="Input.Adults" type="number" class="form-control" min="1" />
        </div>
        <div class="mb-3">
            <label class="form-label">Trẻ em</label>
            <input asp-for="Input.Children" type="number" class="form-control" min="0" />
        </div>
        <div class="mb-3">
            <label class="form-label">Em bé</label>
            <input asp-for="Input.Infants" type="number" class="form-control" min="0" />
        </div>
        <div class="mb-3">
            <label class="form-label">Ghi chú</label>
            <textarea asp-for="Input.Notes" class="form-control"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a href="/Staff/Bookings" class="btn btn-secondary">Hủy</a>
    </form>
</div>
</body>
</html>
