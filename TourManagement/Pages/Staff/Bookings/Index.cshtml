@page
@model TourManagement.Pages.Staff.Bookings.IndexModel
@{
    ViewData["Title"] = "Staff - Quản lý booking";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0">Quản lý booking (Staff)</h2>
        
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @* Flow 4: Chọn tour để xem danh sách khách *@
    <div class="card shadow-sm mb-4">
        <div class="card-header"><strong>Flow 4: Quản lý danh sách khách theo tour</strong></div>
        <div class="card-body">
            <form method="get" class="d-flex gap-2 align-items-end">
                <div class="flex-grow-1">
                    <label class="form-label">Chọn tour</label>
                    <select name="tourId" class="form-select">
                        <option value="">-- Tất cả --</option>
                        @foreach (var t in Model.Tours)
                        {
                                <option value="@t.TourId" selected="@(Model.SelectedTourId == t.TourId)">
                                    @t.Name (@t.Destination?.City)
                                </option>
                            }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Xem</button>
            </form>
            @if (Model.Passengers.Any())
            {
                <div class="mt-3">
                    <h6>Danh sách hành khách (@Model.Passengers.Count người)</h6>
                    <table class="table table-sm">
                        <thead><tr><th>Họ tên</th><th>Booking</th><th>Phân loại</th></tr></thead>
                        <tbody>
                        @foreach (var p in Model.Passengers)
                        {
                            <tr>
                                <td>@p.FullName</td>
                                <td>@p.BookingId</td>
                                <td>@p.Category?.CategoryId</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header"><strong>Danh sách booking</strong></div>
        <div class="card-body">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>BookingId</th>
                        <th>Khách hàng</th>
                        <th>Tour</th>
                        <th>Tổng tiền</th>
                        <th>Payments</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var b in Model.Bookings)
                {
                    var paid = b.Payments?.Any(p => Model.PaidStatusSet.Contains((p.StatusId ?? "").ToUpperInvariant())) ?? false;
                    var isPending = (b.StatusId ?? "").Equals("PENDING", StringComparison.OrdinalIgnoreCase);
                    var isConfirmed = (b.StatusId ?? "").Equals("CONFIRMED", StringComparison.OrdinalIgnoreCase) ||
                                      (b.StatusId ?? "").Equals("APPROVED", StringComparison.OrdinalIgnoreCase) ||
                                      (b.StatusId ?? "").Equals("BOOKED", StringComparison.OrdinalIgnoreCase);
                    <tr>
                        <td>@b.BookingId</td>
                        <td>@b.User?.Name<br /><small class="text-muted">@b.User?.Email</small></td>
                        <td>@b.Group?.Tour?.Name</td>
                        <td>@b.TotalPrice.ToString("N0") ₫</td>
                        <td>
                            @if (b.Payments?.Any() ?? false)
                            {
                                @foreach (var pm in b.Payments!)
                                {
                                    var pmPaid = Model.PaidStatusSet.Contains((pm.StatusId ?? "").ToUpperInvariant());
                                    <div class="d-flex align-items-center gap-1 mb-1">
                                        <span class="badge @(pmPaid ? "bg-success" : "bg-secondary")">@pm.PaymentId: @pm.StatusId</span>
                                        @if (!pmPaid)
                                        {
                                            <form method="post" asp-page-handler="ConfirmPayment" asp-route-paymentId="@pm.PaymentId" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-success">Xác nhận thanh toán</button>
                                            </form>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chưa có payment</span>
                            }
                        </td>
                        <td>@b.StatusId</td>
                        <td class="text-nowrap">
                            @if (isPending)
                            {
                                <form method="post" asp-page-handler="Confirm" asp-route-bookingId="@b.BookingId" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-primary">Xác nhận booking</button>
                                </form>
                            }
                            @if (isConfirmed)
                            {
                                <form method="post" asp-page-handler="Complete" asp-route-bookingId="@b.BookingId" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-info">Hoàn thành</button>
                                </form>
                            }
                            @if (isPending || isConfirmed)
                            {
                                <form method="post" asp-page-handler="Cancel" asp-route-bookingId="@b.BookingId" class="d-inline" onsubmit="return confirm('Xác nhận hủy booking này?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Hủy</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
</body>
</html>
