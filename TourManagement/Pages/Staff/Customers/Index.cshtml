@page
@model TourManagement.Pages.Staff.Customers.IndexModel
@{
    ViewData["Title"] = "Tra cứu Khách hàng";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0">Tra cứu Khách hàng đã đặt Tour</h2>
        <div>
            <a href="/Staff/Tours" class="btn btn-outline-primary">TL khởi hành</a>
            <a href="/Staff/Bookings" class="btn btn-outline-primary ms-2">Duyệt booking</a>
            <a href="/Admin/Dashboard" class="btn btn-outline-secondary ms-2">Dashboard</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="d-flex gap-2 align-items-center">
                <input type="text" asp-for="SearchTerm" class="form-control" placeholder="Tìm theo tên, email hoặc SĐT..." style="max-width:350px;" />
                <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/Staff/Customers" class="btn btn-outline-secondary">Xóa tìm kiếm</a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (!Model.Customers.Any())
            {
                <p class="text-muted m-0">Không tìm thấy khách hàng nào khớp với tìm kiếm.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Khách hàng</th>
                                <th>SĐT</th>
                                <th>Tổng Bookings</th>
                                <th>Tổng Chi tiêu</th>
                                <th>Lần đặt gần nhất</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Customers)
                            {
                                <tr>
                                    <td>
                                        <strong>@c.Name</strong><br />
                                        <small class="text-muted">@c.Email</small>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(c.Phone) ? "-" : c.Phone)</td>
                                    <td><span class="badge bg-info">@c.TotalBookings</span></td>
                                    <td><strong class="text-success">@c.TotalSpent.ToString("N0") ₫</strong></td>
                                    <td>@c.LastBookingDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <a href="/Staff/Customers/Details/@c.UserId" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
